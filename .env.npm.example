# NPM Production Environment Configuration for LitVar-Link
# ======================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env.npm' in the root directory: `cp .env.npm.example .env.npm`
# 2. Edit '.env.npm' with your specific domain and server settings
# 3. This file will be used by `docker-compose.npm.yml` for NPM deployment

# ===========================================
# Docker Network Configuration (CRITICAL)
# ===========================================

# Name of the Docker network that Nginx Proxy Manager uses
# This is typically 'npm_default' if NPM was started from a directory named 'npm'
# Verify with 'docker network ls' on your server if unsure
NPM_SHARED_NETWORK_NAME=npm_default

# ===========================================
# Public Domain Configuration
# ===========================================

# Your public domain name (replace with your actual domain)
LITVAR_LINK_PUBLIC_DOMAIN=litvar.yourdomain.com
LITVAR_LINK_PUBLIC_URL=https://litvar.yourdomain.com

# API base URL for external access (if different from main domain)
LITVAR_LINK_API_PUBLIC_URL=https://litvar.yourdomain.com/api

# ===========================================
# Server Configuration (Production)
# ===========================================

# Server binding (keep as 0.0.0.0 for container networking)
LITVAR_LINK_HOST=0.0.0.0
LITVAR_LINK_PORT=8000

# Transport mode for production
LITVAR_LINK_TRANSPORT_MODE=unified

# Production settings
LITVAR_LINK_RELOAD=false

# ===========================================
# Logging Configuration (Production)
# ===========================================

# Production logging level
LITVAR_LINK_LOG_LEVEL=INFO

# JSON format for structured logging in production
LITVAR_LINK_LOG_FORMAT=json

# ===========================================
# CORS Configuration (Production)
# ===========================================

# CORS origins - MUST include your public domain
LITVAR_LINK_CORS_ORIGINS=["https://litvar.yourdomain.com"]

# CORS credentials
LITVAR_LINK_CORS_ALLOW_CREDENTIALS=true

# CORS methods
LITVAR_LINK_CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]

# CORS headers
LITVAR_LINK_CORS_ALLOW_HEADERS=["*"]

# ===========================================
# Rate Limiting Configuration
# ===========================================

# LitVar2 API rate limiting (requests per second)
LITVAR_LINK_RATE_LIMIT=2.0

# Rate limit burst capacity
LITVAR_LINK_RATE_LIMIT_BURST=5

# ===========================================
# Caching Configuration
# ===========================================

# Cache TTL in seconds (3600 = 1 hour)
LITVAR_LINK_CACHE_TTL=3600

# Maximum cache size
LITVAR_LINK_CACHE_MAX_SIZE=1000

# ===========================================
# Production Gunicorn Configuration
# ===========================================

# Number of Gunicorn worker processes
GUNICORN_WORKERS=4

# Worker threads per process
GUNICORN_THREADS=4

# Gunicorn log level (warning recommended for production)
GUNICORN_LOG_LEVEL=warning

# Container port (keep as 8000)
PORT=8000

# ===========================================
# External API Configuration
# ===========================================

# LitVar2 API base URL (usually no need to change)
LITVAR_LINK_API_BASE_URL=https://www.ncbi.nlm.nih.gov/research/litvar2-api

# API request timeout in seconds
LITVAR_LINK_API_TIMEOUT=30

# ===========================================
# Environment Identification
# ===========================================

# Environment identifier for logging and monitoring
ENVIRONMENT=production

# Deployment type for logging labels
DEPLOYMENT_TYPE=npm