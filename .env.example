# LitVar-Link Environment Configuration Template
# Copy this file to .env and customize the values for your deployment

# ===========================================
# Server Configuration
# ===========================================

# Server binding configuration
LITVAR_LINK_HOST=127.0.0.1
LITVAR_LINK_PORT=8000

# Transport mode: unified, http, or stdio
LITVAR_LINK_TRANSPORT_MODE=unified

# Development settings
LITVAR_LINK_RELOAD=false

# ===========================================
# Logging Configuration  
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LITVAR_LINK_LOG_LEVEL=INFO

# Log format: console or json
LITVAR_LINK_LOG_FORMAT=console

# ===========================================
# CORS Configuration
# ===========================================

# Allowed origins for CORS (JSON array format)
LITVAR_LINK_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# CORS credentials
LITVAR_LINK_CORS_ALLOW_CREDENTIALS=true

# CORS methods (JSON array format)
LITVAR_LINK_CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]

# CORS headers (JSON array format)
LITVAR_LINK_CORS_ALLOW_HEADERS=["*"]

# ===========================================
# Rate Limiting Configuration
# ===========================================

# LitVar2 API rate limiting (requests per second)
LITVAR_LINK_RATE_LIMIT=2.0

# Rate limit burst capacity
LITVAR_LINK_RATE_LIMIT_BURST=5

# ===========================================
# Caching Configuration
# ===========================================

# Cache TTL in seconds (3600 = 1 hour)
LITVAR_LINK_CACHE_TTL=3600

# Maximum cache size
LITVAR_LINK_CACHE_MAX_SIZE=1000

# ===========================================
# Production Docker Configuration
# ===========================================

# Gunicorn worker processes (production)
GUNICORN_WORKERS=4

# Gunicorn worker threads per process
GUNICORN_THREADS=4

# Gunicorn log level
GUNICORN_LOG_LEVEL=info

# Container port override
PORT=8000

# ===========================================
# External API Configuration
# ===========================================

# LitVar2 API base URL (usually no need to change)
LITVAR_LINK_API_BASE_URL=https://www.ncbi.nlm.nih.gov/research/litvar2-api

# API request timeout in seconds
LITVAR_LINK_API_TIMEOUT=30

# ===========================================
# Development & Testing
# ===========================================

# Environment identifier
ENVIRONMENT=development

# Debug mode (for testing only)
DEBUG=false