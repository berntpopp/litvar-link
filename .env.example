# LitVar-Link Environment Configuration Template
# Copy this file to .env and customize. Nested config fields use a double
# underscore: LITVAR_LINK_<SECTION>__<FIELD> (env_nested_delimiter="__").

# ---- Server ----
LITVAR_LINK_HOST=127.0.0.1
LITVAR_LINK_PORT=8000
LITVAR_LINK_TRANSPORT_MODE=unified
LITVAR_LINK_RELOAD=false
LITVAR_LINK_MCP_PATH=/mcp

# ---- Logging ----
LITVAR_LINK_LOG_LEVEL=INFO
LITVAR_LINK_LOG_FORMAT=console

# ---- CORS (JSON array form) ----
LITVAR_LINK_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
LITVAR_LINK_CORS_ALLOW_CREDENTIALS=true

# ---- LitVar2 API (nested: api.*) ----
LITVAR_LINK_API__BASE_URL=https://www.ncbi.nlm.nih.gov/research/litvar2-api/
LITVAR_LINK_API__TIMEOUT=30
LITVAR_LINK_API__RATE_LIMIT_PER_SECOND=2.0
LITVAR_LINK_API__BURST_SIZE=5
LITVAR_LINK_API__MAX_RETRIES=3
LITVAR_LINK_API__RETRY_DELAY=1.0

# ---- Caching (nested: cache.*) ----
LITVAR_LINK_CACHE__TTL=3600
LITVAR_LINK_CACHE__SIZE=1000
LITVAR_LINK_CACHE__STATS_ENABLED=true
