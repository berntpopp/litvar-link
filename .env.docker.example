# LitVar-Link Docker / Nginx-Proxy-Manager Environment Template
# Copy to .env.docker and edit. Used by docker-compose overlays.
# Nested config fields use a double underscore (env_nested_delimiter="__").

# ---- Docker network (NPM) ----
NPM_SHARED_NETWORK_NAME=npm_default

# ---- Public domain ----
LITVAR_LINK_PUBLIC_DOMAIN=litvar-link.genefoundry.org
LITVAR_LINK_PUBLIC_URL=https://litvar-link.genefoundry.org

# ---- Server (container) ----
LITVAR_LINK_HOST=0.0.0.0
LITVAR_LINK_PORT=8000
LITVAR_LINK_TRANSPORT_MODE=unified
LITVAR_LINK_RELOAD=false

# ---- Logging ----
LITVAR_LINK_LOG_LEVEL=INFO
LITVAR_LINK_LOG_FORMAT=json

# ---- CORS ----
LITVAR_LINK_CORS_ORIGINS=["https://litvar-link.genefoundry.org"]
LITVAR_LINK_CORS_ALLOW_CREDENTIALS=true

# ---- LitVar2 API (nested) ----
LITVAR_LINK_API__BASE_URL=https://www.ncbi.nlm.nih.gov/research/litvar2-api/
LITVAR_LINK_API__TIMEOUT=30

# ---- Caching (nested) ----
LITVAR_LINK_CACHE__TTL=3600
LITVAR_LINK_CACHE__SIZE=1000

# ---- Gunicorn (production container) ----
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_LOG_LEVEL=warning
PORT=8000
ENVIRONMENT=production
DEPLOYMENT_TYPE=docker
